# Copy this file to .env and fill in your values
# Never commit .env to git

# CANoe config path (HIL bench)
CANOE_CONFIG_PATH=C:\HIL\configs\BCM_SDV_Test.cfg

# Jira / Xray
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_PROJECT_KEY=BCM
JIRA_PLAN_KEY=BCM-50
XRAY_CLIENT_ID=your-xray-client-id
XRAY_CLIENT_SECRET=your-xray-client-secret

# Slack webhook (for CI failure notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
